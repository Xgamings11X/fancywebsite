--- a/styles/globals.css
+++ b/styles/globals.css
@@ -3957,3 +3957,1653 @@ body {
   .cart-code-row { grid-template-columns: 1fr; }
   .cart-apply-btn { min-height: 42px; }
 }
+
+/* ======================================================================
+   ORANGE REWORK — rollback visual besar, pertahankan server endpoint card
+   Solid hex colors only. No public gradients.
+   ====================================================================== */
+:root {
+  --orange-50: #fff7ed;
+  --orange-100: #ffedd5;
+  --orange-200: #fed7aa;
+  --orange-300: #fdba74;
+  --orange-400: #fb923c;
+  --orange-500: #f97316;
+  --orange-600: #ea580c;
+  --orange-700: #c2410c;
+  --orange-900: #7c2d12;
+  --ink-950: #11100f;
+  --ink-900: #1c1917;
+  --ink-700: #44403c;
+  --ink-500: #78716c;
+  --paper: #fffdf9;
+  --paper-soft: #faf8f5;
+  --line-warm: #e8e2dc;
+}
+
+body,
+.public-shell,
+.login-modal-shell,
+.fn-modal {
+  font-family: 'Plus Jakarta Sans', Arial, sans-serif;
+}
+
+.font-space,
+.public-shell h1,
+.public-shell h2,
+.public-shell h3,
+.public-shell h4,
+.login-modal-shell h1,
+.login-modal-shell h2,
+.login-modal-shell h3,
+.fn-modal h1,
+.fn-modal h2,
+.fn-modal h3 {
+  font-family: 'Outfit', 'Plus Jakarta Sans', Arial, sans-serif;
+}
+
+.orange-public-theme,
+.orange-public-theme * {
+  --orange-focus: #f9731640;
+}
+
+.orange-public-theme {
+  color: var(--ink-950);
+  background: var(--paper);
+  background-image: none !important;
+}
+
+.orange-public-theme :focus-visible,
+.login-modal-shell :focus-visible,
+.fn-modal :focus-visible {
+  outline: 3px solid var(--orange-focus);
+  outline-offset: 3px;
+}
+
+.orange-public-theme .public-eyebrow {
+  color: var(--orange-600);
+}
+.orange-public-theme .public-eyebrow::before {
+  background: var(--orange-500);
+}
+.orange-public-theme .public-section-heading h2 {
+  color: var(--ink-950);
+  letter-spacing: -.035em;
+}
+.orange-public-theme .public-section-heading p {
+  color: var(--ink-500);
+}
+
+/* Navbar */
+.orange-public-theme .public-nav {
+  border-color: #ffffff;
+  border-radius: 18px;
+  background: #ffffff;
+  background-image: none !important;
+  box-shadow: 0 14px 42px #24170f1a;
+}
+.orange-public-theme .public-nav.is-scrolled {
+  border-color: var(--line-warm);
+  box-shadow: 0 10px 30px #24170f20;
+}
+.orange-public-theme .public-nav-logo {
+  border: 1px solid var(--orange-100);
+  background: var(--orange-50);
+}
+.orange-public-theme .public-nav-brand-copy strong {
+  color: var(--ink-950);
+  font-family: 'Outfit', sans-serif;
+  font-size: 15px;
+}
+.orange-public-theme .public-nav-brand-copy small {
+  color: var(--orange-600);
+}
+.orange-public-theme .public-nav-links {
+  border-color: var(--line-warm);
+  background: var(--paper-soft);
+}
+.orange-public-theme .public-nav-link {
+  color: var(--ink-500);
+}
+.orange-public-theme .public-nav-link:hover {
+  color: var(--ink-950);
+  background: #ffffff;
+}
+.orange-public-theme .public-nav-link.active {
+  color: #ffffff;
+  background: var(--orange-500);
+}
+.orange-public-theme .public-nav-login,
+.orange-public-theme .public-mobile-login-button {
+  color: #ffffff;
+  background: var(--orange-500);
+  background-image: none !important;
+}
+.orange-public-theme .public-nav-login:hover,
+.orange-public-theme .public-mobile-login-button:hover {
+  background: var(--orange-600);
+}
+.orange-public-theme .public-nav-player-card,
+.orange-public-theme .public-nav-icon-button,
+.orange-public-theme .public-nav-menu-button {
+  border-color: var(--line-warm);
+}
+.orange-public-theme .public-nav-player-card small {
+  color: var(--orange-600);
+}
+.orange-public-theme .public-nav-icon-button:hover,
+.orange-public-theme .public-nav-menu-button:hover,
+.orange-public-theme .public-nav-menu-button.active {
+  color: #ffffff;
+  border-color: var(--orange-500);
+  background: var(--orange-500);
+}
+.orange-public-theme .public-mobile-menu {
+  border-color: var(--line-warm);
+  background: #ffffff;
+  box-shadow: 0 18px 46px #24170f24;
+}
+.orange-public-theme .public-mobile-link.active > span,
+.orange-public-theme .public-mobile-link:hover > span {
+  color: #ffffff;
+  background: var(--orange-500);
+}
+
+/* Home — status and endpoint cards deliberately not restyled */
+.home-orange-page {
+  background: var(--paper);
+  background-image: none !important;
+}
+.home-orange-page .home-hero {
+  min-height: 790px;
+  align-items: stretch;
+  padding: 150px 24px 138px;
+  color: #ffffff;
+  background: #171411;
+  background-image: none !important;
+}
+.home-orange-page .home-hero::before {
+  top: -320px;
+  right: -250px;
+  left: auto;
+  width: 720px;
+  height: 720px;
+  border: 1px solid #f9731638;
+  background: #f9731612;
+}
+.home-orange-page .home-hero::after {
+  right: auto;
+  bottom: -480px;
+  left: -340px;
+  width: 860px;
+  height: 860px;
+  border: 1px solid #ffffff0f;
+}
+.home-orange-hero-grid {
+  position: relative;
+  z-index: 2;
+  display: grid;
+  width: min(1160px, 100%);
+  grid-template-columns: minmax(0, 1.2fr) minmax(320px, .8fr);
+  align-items: center;
+  gap: clamp(36px, 7vw, 90px);
+  margin: auto;
+}
+.home-orange-page .home-hero-content {
+  width: auto;
+  align-items: flex-start;
+  text-align: left;
+}
+.home-orange-page .home-hero-kicker {
+  margin: 0 0 18px;
+  color: var(--orange-400);
+  font-size: 10px;
+}
+.home-orange-page .home-hero h1 {
+  max-width: 760px;
+  color: #ffffff;
+  font-size: clamp(48px, 7vw, 84px);
+  line-height: .98;
+  letter-spacing: -.055em;
+}
+.home-orange-page .home-hero h1 strong {
+  color: var(--orange-400);
+  font-weight: 800;
+}
+.home-orange-page .home-hero-content > p {
+  width: min(650px, 100%);
+  margin: 24px 0 0;
+  color: #d6d0ca;
+  font-size: 15px;
+  line-height: 1.8;
+}
+.home-orange-page .home-hero-actions {
+  justify-content: flex-start;
+  margin-top: 28px;
+}
+.home-orange-page .home-hero-actions button {
+  color: #ffffff;
+  border-color: var(--orange-500);
+  background: var(--orange-500);
+}
+.home-orange-page .home-hero-actions button:hover {
+  background: var(--orange-600);
+}
+.home-orange-page .home-hero-actions a {
+  color: #ffffff;
+  border-color: #4b4540;
+  background: #2a2521;
+}
+.home-orange-page .home-hero-actions a:hover {
+  background: #38312c;
+}
+.home-hero-proof {
+  display: grid;
+  width: 100%;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 1px;
+  margin-top: 34px;
+  overflow: hidden;
+  border: 1px solid #ffffff14;
+  border-radius: 14px;
+  background: #ffffff14;
+}
+.home-hero-proof > div {
+  display: grid;
+  gap: 3px;
+  padding: 15px;
+  background: #221e1a;
+}
+.home-hero-proof strong {
+  color: #ffffff;
+  font-family: 'Outfit', sans-serif;
+  font-size: 15px;
+}
+.home-hero-proof span {
+  color: #9f9891;
+  font-size: 9px;
+}
+.home-brand-card {
+  position: relative;
+  display: grid;
+  gap: 22px;
+  padding: 28px;
+  border: 1px solid #ffffff17;
+  border-radius: 22px;
+  background: #221e1a;
+  background-image: none !important;
+  box-shadow: 0 24px 70px #00000038;
+}
+.home-brand-card::before {
+  position: absolute;
+  top: 0;
+  right: 24px;
+  width: 72px;
+  height: 5px;
+  border-radius: 0 0 5px 5px;
+  background: var(--orange-500);
+  content: '';
+}
+.home-brand-card-head {
+  display: flex;
+  align-items: center;
+  gap: 14px;
+}
+.home-brand-logo {
+  display: grid;
+  width: 58px;
+  height: 58px;
+  place-items: center;
+  overflow: hidden;
+  border: 1px solid #ffffff17;
+  border-radius: 16px;
+  background: #ffffff;
+}
+.home-brand-logo img { width: 100%; height: 100%; object-fit: contain; }
+.home-brand-card-head > div { display: grid; gap: 3px; }
+.home-brand-card-head small {
+  color: var(--orange-400);
+  font-size: 9px;
+  font-weight: 800;
+  letter-spacing: .15em;
+}
+.home-brand-card-head strong {
+  color: #ffffff;
+  font-family: 'Outfit', sans-serif;
+  font-size: 21px;
+}
+.home-brand-card > p {
+  margin: 0;
+  color: #b9b1aa;
+  font-size: 12px;
+  line-height: 1.75;
+}
+.home-brand-list { display: grid; gap: 9px; }
+.home-brand-list span {
+  display: flex;
+  align-items: center;
+  gap: 9px;
+  color: #f1ece7;
+  font-size: 11px;
+  font-weight: 700;
+}
+.home-brand-list svg { color: var(--orange-400); }
+
+.home-about-orange,
+.home-features-section,
+.home-famous-section,
+.home-support-strip {
+  width: min(1160px, calc(100% - 40px));
+  margin-inline: auto;
+}
+.home-about-orange {
+  display: grid;
+  grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr);
+  gap: clamp(42px, 8vw, 100px);
+  padding: 100px 0;
+}
+.home-about-copy h2 {
+  margin: 15px 0 20px;
+  color: var(--ink-950);
+  font-size: clamp(36px, 5vw, 58px);
+  line-height: 1.03;
+  letter-spacing: -.045em;
+}
+.home-about-copy p {
+  margin: 0 0 14px;
+  color: var(--ink-500);
+  font-size: 14px;
+  line-height: 1.8;
+}
+.home-inline-link {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  margin-top: 12px;
+  color: var(--orange-600);
+  font-size: 11px;
+  font-weight: 800;
+  text-decoration: none;
+}
+.home-about-metrics { display: grid; gap: 10px; }
+.home-about-metrics article {
+  display: grid;
+  grid-template-columns: 110px minmax(0, 1fr);
+  align-items: center;
+  gap: 4px 18px;
+  padding: 22px;
+  border: 1px solid var(--line-warm);
+  border-radius: 16px;
+  background: #ffffff;
+}
+.home-about-metrics article > span {
+  grid-row: 1 / 3;
+  color: var(--orange-600);
+  font-size: 9px;
+  font-weight: 800;
+  letter-spacing: .12em;
+}
+.home-about-metrics strong {
+  color: var(--ink-950);
+  font-family: 'Outfit', sans-serif;
+  font-size: 18px;
+}
+.home-about-metrics small { color: var(--ink-500); font-size: 10px; }
+
+.home-orange-page .home-features-section {
+  padding: 88px 0;
+  border-top: 1px solid var(--line-warm);
+}
+.home-orange-page .home-feature-grid {
+  display: grid;
+  grid-template-columns: repeat(4, minmax(0, 1fr));
+  gap: 14px;
+}
+.home-orange-page .home-feature-grid article {
+  min-height: 250px;
+  padding: 24px;
+  border: 1px solid var(--line-warm);
+  border-radius: 18px;
+  background: #ffffff;
+  box-shadow: none;
+}
+.home-orange-page .home-feature-grid article:hover {
+  border-color: var(--orange-300);
+  transform: translateY(-3px);
+}
+.home-orange-page .home-feature-number { color: #b8afa7; }
+.home-orange-page .home-feature-icon {
+  color: #ffffff;
+  background: var(--orange-500);
+}
+.home-orange-page .home-feature-grid h3 { color: var(--ink-950); }
+.home-orange-page .home-feature-grid p { color: var(--ink-500); }
+
+.home-famous-section {
+  display: grid;
+  grid-template-columns: minmax(0, 1.1fr) minmax(330px, .9fr);
+  gap: 50px;
+  margin-bottom: 90px;
+  padding: 54px;
+  border: 1px solid #302a25;
+  border-radius: 24px;
+  color: #ffffff;
+  background: #1c1917;
+  background-image: none !important;
+}
