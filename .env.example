# ================================================================
# MINECRAFT STORE — .env.local
# Rename file ini → .env.local
# JANGAN commit .env.local ke Git!
# ================================================================

# ── Website URL ─────────────────────────────────────────────────
# VPS langsung pakai IP:port
NEXT_PUBLIC_BASE_URL=http://IP_SERVER:PORT
# Setelah domain aktif (dengan Nginx reverse proxy):
# NEXT_PUBLIC_BASE_URL=https://domainmu.com

# ── Data Folder ──────────────────────────────────────────────────
# OPSIONAL — kode otomatis mendeteksi:
#   Pterodactyl → /home/container/data (auto)
#   VPS/Docker  → /app/data            (auto)
#   Development → ./data               (auto)
#
# Kalau ingin override manual:
# DATA_DIR=/home/container/data    ← Pterodactyl
# DATA_DIR=/var/data/mcstore       ← VPS custom path
# DATA_DIR=./data                  ← local dev
#
# Di Pterodactyl: set via panel → Server → Startup → Environment Variables
# DATA_DIR = /home/container/data

# ── Plugin ShadowynAPI HTTP ──────────────────────────────────────
PLUGIN_HTTP_URL=http://IP_SERVER_MINECRAFT:12025
PLUGIN_SERVER_KEY=isi-server-key-dari-config-plugin

# ── Midtrans Payment Gateway ─────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_ENV=sandbox
MIDTRANS_ENV=sandbox

# ── JWT Secret ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-random-hex-64-karakter

# ── Admin Panel ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GantiPasswordIni123!

# ── Status Server Minecraft ───────────────────────────────────────
MC_STATUS_URL=https://api.mcsrvstat.us/2/ip-atau-domain-server-mc

# ── Discord Webhooks ─────────────────────────────────────────────
# ADMIN menerima semua status transaksi + invoice.
DISCORD_WEBHOOK_ADMIN=https://discord.com/api/webhooks/xxx/admin
# PLAYER hanya menerima transaksi sukses (opsional).
DISCORD_WEBHOOK_PLAYER=https://discord.com/api/webhooks/xxx/player
# Alias lama; dipakai sebagai fallback bila ADMIN kosong.
DISCORD_WEBHOOK_TX=
# Ticket fallback / arsip support.
DISCORD_WEBHOOK_REPORT=https://discord.com/api/webhooks/xxx/report

# ── Social Media Links ───────────────────────────────────────────
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/xxxxxx
NEXT_PUBLIC_VOTE_URL=https://minecraft-server-list.com/server/xxxxx/vote/
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@servermu
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@servermu
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/628xxxxxxxxxx
NEXT_PUBLIC_FAMOUS_APPLY_URL=https://discord.gg/xxxxxx

# ── Leaderboard Endpoint ──────────────────────────────────────────
# Base URL endpoint leaderboard — board & limit otomatis ditambahkan sebagai query param.
# Website akan memanggil: <LEADERBOARD_ENDPOINT>?board=balance&limit=10
#
# Contoh (ShadowynAPI):
LEADERBOARD_ENDPOINT=https://www.shadowyn.id/api/leaderboard
#
# Contoh lain (self-hosted, port 12025):
# LEADERBOARD_ENDPOINT=http://IP_SERVER_MC:12025/api/leaderboard
#
# Kosongkan untuk mode PUSH (plugin kirim data ke /api/plugin/leaderboard):
# LEADERBOARD_ENDPOINT=
#
# ── Board name alias (opsional) ──────────────────────────────────
# Jika nama board di plugin berbeda, override dengan variabel ini.
# Format: LEADERBOARD_BOARD_<NAMA_BOARD_WEBSITE>=nama_board_plugin
# Contoh: board "balance" di website dipanggil sebagai "money" ke endpoint:
# LEADERBOARD_BOARD_BALANCE=money
# LEADERBOARD_BOARD_AURASKILLS=auraskills
# LEADERBOARD_BOARD_VOTES=votes
# LEADERBOARD_BOARD_PLAYTIME=playtime
# LEADERBOARD_BOARD_PLAYERPOINTS=playerpoints

# ── Image Upload Provider ─────────────────────────────────────────
# Kode otomatis pilih provider berdasarkan env yang diset.
# Prioritas: Cloudinary → AWS S3 → Local
#
# ── OPSI 1: Cloudinary (REKOMENDASI untuk Vercel/serverless) ──────
# Daftar gratis di: https://cloudinary.com/users/register_free
# Plan gratis: 25GB storage + 25GB bandwidth/bulan
# Setelah daftar, buka Dashboard → copy Cloud Name, API Key, API Secret
#
# CLOUDINARY_CLOUD_NAME=nama-cloud-kamu
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLOUDINARY_FOLDER=fancystore          # opsional, default: fancystore
#
# ── OPSI 2: AWS S3 ────────────────────────────────────────────────
# Atau pakai DigitalOcean Spaces / Backblaze B2 (kompatibel S3)
# Buat bucket di AWS S3, set public read policy, buat IAM user
#
# AWS_S3_BUCKET=nama-bucket-kamu
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_S3_REGION=ap-southeast-1          # region terdekat (Singapore)
#
# Untuk DigitalOcean Spaces (endpoint berbeda):
# AWS_S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
# AWS_S3_PUBLIC_URL=https://nama-bucket.sgp1.cdn.digitaloceanspaces.com
#
# ── OPSI 3: Local (default — cocok VPS/Pterodactyl) ───────────────
# Tidak perlu env tambahan. Gambar disimpan di public/uploads/
# Tidak berfungsi di Vercel (filesystem read-only).

# ─── Discord Ticket Bridge (dua arah Web ↔ Discord) ───────────
# Buat Discord Bot di Developer Portal, aktifkan bot, lalu invite dengan izin:
# View Channels, Manage Channels, Send Messages, Read Message History.
# Jangan pernah memakai webhook token sebagai DISCORD_BOT_TOKEN.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_TICKET_CATEGORY_ID=
DISCORD_SUPPORT_ROLE_ID=
# Opsional: channel ticket yang ditutup dipindah ke kategori arsip.
DISCORD_TICKET_ARCHIVE_CATEGORY_ID=
# Opsional: true = channel dihapus saat cleanup, false = dipindah/diarsipkan.
DISCORD_TICKET_DELETE_ON_CLEANUP=false
