# ================================================================
# MINECRAFT STORE — .env.local
# Rename file ini → .env.local
# JANGAN commit .env.local ke Git!
# ================================================================

# ── Website URL ─────────────────────────────────────────────────
# VPS langsung pakai IP:port
NEXT_PUBLIC_BASE_URL=http://IP_SERVER:PORT
# Setelah domain aktif (dengan Nginx reverse proxy):
# NEXT_PUBLIC_BASE_URL=https://domainmu.com

# ── Data Folder ──────────────────────────────────────────────────
# OPSIONAL — kode otomatis mendeteksi:
#   Pterodactyl → /home/container/data (auto)
#   VPS/Docker  → /app/data            (auto)
#   Development → ./data               (auto)
#
# Kalau ingin override manual:
# DATA_DIR=/home/container/data    ← Pterodactyl
# DATA_DIR=/var/data/mcstore       ← VPS custom path
# DATA_DIR=./data                  ← local dev
#
# Di Pterodactyl: set via panel → Server → Startup → Environment Variables
# DATA_DIR = /home/container/data

# ── Plugin ShadowynAPI HTTP ──────────────────────────────────────
PLUGIN_HTTP_URL=http://IP_SERVER_MINECRAFT:12025
PLUGIN_SERVER_KEY=isi-server-key-dari-config-plugin

# ── Midtrans Payment Gateway ─────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_ENV=sandbox
MIDTRANS_ENV=sandbox

# ── JWT Secret ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-random-hex-64-karakter

# ── Admin Panel ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GantiPasswordIni123!

# ── Status Server Minecraft ───────────────────────────────────────
MC_STATUS_URL=https://api.mcsrvstat.us/2/ip-atau-domain-server-mc

# ── Discord Webhooks ─────────────────────────────────────────────
DISCORD_WEBHOOK_TX=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_REPORT=https://discord.com/api/webhooks/xxx/zzz

# ── Social Media Links ───────────────────────────────────────────
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/xxxxxx
NEXT_PUBLIC_VOTE_URL=https://minecraft-server-list.com/server/xxxxx/vote/
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@servermu
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@servermu
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/628xxxxxxxxxx
NEXT_PUBLIC_FAMOUS_APPLY_URL=https://discord.gg/xxxxxx

# ── Leaderboard Endpoint ──────────────────────────────────────────
# Base URL endpoint leaderboard — board & limit otomatis ditambahkan sebagai query param.
# Website akan memanggil: <LEADERBOARD_ENDPOINT>?board=balance&limit=10
#
# Contoh (ShadowynAPI):
LEADERBOARD_ENDPOINT=https://www.shadowyn.id/api/leaderboard
#
# Contoh lain (self-hosted, port 12025):
# LEADERBOARD_ENDPOINT=http://IP_SERVER_MC:12025/api/leaderboard
#
# Kosongkan untuk mode PUSH (plugin kirim data ke /api/plugin/leaderboard):
# LEADERBOARD_ENDPOINT=
#
# ── Board name alias (opsional) ──────────────────────────────────
# Jika nama board di plugin berbeda, override dengan variabel ini.
# Format: LEADERBOARD_BOARD_<NAMA_BOARD_WEBSITE>=nama_board_plugin
# Contoh: board "balance" di website dipanggil sebagai "money" ke endpoint:
# LEADERBOARD_BOARD_BALANCE=money
# LEADERBOARD_BOARD_AURASKILLS=auraskills
# LEADERBOARD_BOARD_VOTES=votes
# LEADERBOARD_BOARD_PLAYTIME=playtime
# LEADERBOARD_BOARD_PLAYERPOINTS=playerpoints
